// datasource and generator configurations
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

// ------------------------------------------------------
// ENUMS

enum Role {
  CLERK
  SUPERVISOR
  OWNER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentType {
  CASH
  CREDIT
}

enum RateStatus {
  SETTLED
  OPEN
}

// ------------------------------------------------------
// MODELS

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String // Hashed password
  name      String
  role      Role     @default(CLERK)
  isActive  Boolean  @default(true) // To deactivate fired/left clerks
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions         Transaction[] @relation("ClerkTransactions")
  createdVoidRequests  VoidRequest[] @relation("RequestedByClerk")
  actionedVoidRequests VoidRequest[] @relation("ActionedByAdmin")
  shifts               Shift[]
  payments             Payment[]     @relation("AdminReceivedPayments")
}

model Shift {
  id                    String    @id // Client-generated or Server-generated unique token (e.g., SHIFT-shikhar-A3F9B)
  userId                String
  status                String    @default("OPEN")
  openedAt              DateTime  @default(now())
  closedAt              DateTime?
  totalCashCollected    Float     @default(0.0)
  totalTonnageProcessed Float     @default(0.0)

  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]
}

model Material {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions Transaction[]
}

model Customer {
  id                    String @id @default(uuid())
  name                  String @unique
  initialOpeningBalance Float  @default(0)

  outstandingBalance Float         @default(0) // Running tally of debt (grandTotal - all payments)
  creditLimit        Float         @default(100000)
  // Relations
  transactions       Transaction[]
  payments           Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id            String  @id @default(uuid())
  receiptNumber String  @unique
  amountPaid    Float
  paymentMode   String // "CASH", "BANK_TRANSFER", "UPI", "CHEQUE"
  referenceNo   String?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id])
  receivedById String?
  receivedBy   User?    @relation("AdminReceivedPayments", fields: [receivedById], references: [id])
}

model Transaction {
  id            String  @id @default(uuid())
  receiptNumber String  @unique
  vehicleNumber String
  site          String?

  // Material Details
  materialQuantity Float @default(0)
  materialRate     Float @default(0)
  materialAmount   Float @default(0)

  // Royalty Details
  royaltyQuantity Float? @default(0)
  royaltyRate     Float? @default(0)
  royaltyAmount   Float? @default(0)

  // Financial Snapshots at Gate Out
  grandTotal  Float       @default(0)
  paymentMode PaymentType @default(CREDIT)
  amountPaid  Float       @default(0)
  balance     Float       @default(0)

  rateStatus RateStatus @default(SETTLED)

  // Operational Control Logs
  isVoided  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customerId  String
  customer    Customer     @relation(fields: [customerId], references: [id])
  clerkId     String
  clerk       User         @relation("ClerkTransactions", fields: [clerkId], references: [id])
  materialId  String
  material    Material     @relation(fields: [materialId], references: [id])
  voidRequest VoidRequest?
  shift       Shift?       @relation(fields: [shiftId], references: [id])
  shiftId     String?
}

model VoidRequest {
  id         String        @id @default(uuid())
  reason     String
  status     RequestStatus @default(PENDING)
  adminNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  clerkId     String
  requestedBy User   @relation("RequestedByClerk", fields: [clerkId], references: [id])

  adminId    String?
  actionedBy User?   @relation("ActionedByAdmin", fields: [adminId], references: [id])
}
